    <!-- Chart Configuration Script -->
    <script>
        const ctx = document.getElementById('growthChart').getContext('2d');
        
        // Mathematical Constants derived for typical Kedah-Kelantan cattle parameters
        const L = 220;    // Maximum carrying capacity / asymptotic weight minus base weight adjustment
        const k = 0.08;   // Growth velocity coefficient
        const t0 = 30;    // Inflection point age in weeks (point of maximum growth rate)
        const base = 15;  // Average weaning weight in kg
        
        // Generate dataset points from week 0 to week 70
        const weeksData = [];
        const weightData = [];
        
        for (let t = 0; t <= 70; t++) {
            weeksData.push(t);
            // f(t) formula
            let weight = (L / (1 + Math.exp(-k * (t - t0)))) + base;
            weightData.push(parseFloat(weight.toFixed(2)));
        }

        // Initialize Chart.js with standard configuration and animation rules
        const growthChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: weeksData,
                datasets: [{
                    label: 'Cattle Weight (kg)',
                    data: weightData,
                    borderColor: '#059669',
                    borderWidth: 3,
                    backgroundColor: 'rgba(5, 150, 105, 0.05)',
                    fill: true,
                    tension: 0.2,
                    pointRadius: 0,
                    pointHoverRadius: 6,
                    pointHoverBackgroundColor: '#f59e0b',
                    pointHoverBorderColor: '#fff',
                    pointHoverBorderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: {
                        title: { display: true, text: 'Time Post-Weaning (Weeks)', color: '#475569', font: { weight: 'bold' } },
                        grid: { color: '#f1f5f9' }
                    },
                    y: {
                        title: { display: true, text: 'Live Weight (kg)', color: '#475569', font: { weight: 'bold' } },
                        grid: { color: '#f1f5f9' },
                        suggestedMax: 250
                    }
                },
                // Trigger action upon selection within chart canvas
                onClick: (e) => {
                    const points = growthChart.getElementsAtEventForMode(e, 'nearest', { intersect: false }, true);
                    if (points.length > 0) {
                        const idx = points[0].index;
                        evaluateDerivativeAtPoint(idx);
                    }
                },
                hover: {
                    mode: 'nearest',
                    intersect: false
                },
                animation: {
                    duration: 1200,
                    easing: 'easeOutQuart'
                }
            }
        });

        // Compute the f'(x) value and generate natural language outputs
        function evaluateDerivativeAtPoint(week) {
            // Function value: f(t)
            const weight = weightData[week];
            
            // Derivative evaluation: f'(t) = (L * k * e^(-k*(t-t0))) / (1 + e^(-k*(t-t0)))^2
            const exponent = -k * (week - t0);
            const expTerm = Math.exp(exponent);
            const derivativeVal = (L * k * expTerm) / Math.pow((1 + expTerm), 2);
            
            const finalRate = derivativeVal.toFixed(3);

            // Interface Content Updates
            document.getElementById('promptText').classList.add('hidden');
            const resultCard = document.getElementById('resultContent');
            resultCard.classList.remove('hidden');
            
            document.getElementById('outWeek').innerText = week;
            document.getElementById('outWeight').innerText = weight;
            document.getElementById('outDerivative').innerText = finalRate;
            
            // Contextual Bioscience Translation Engines
            let explanation = "";
            if (week < 15) {
                explanation = `At Week ${week}, the animal is adapting to post-weaning solid feed options. Growth acceleration is positive but slow. The animal gains ${finalRate} kg this week.`;
            } else if (week >= 15 && week <= 25) {
                explanation = `The cattle are entering an aggressive metabolic phase. Muscle structural development is scaling efficiently, and weight increase is stepping up fast.`;
            } else if (week > 25 && week <= 35) {
                explanation = `CRITICAL WINDOW: At Week ${week}, growth rate peaks close to its theoretical absolute max (~1.76 kg/week). Feed conversion is optimized; ideal period for nutrient-dense feeding cycles.`;
            } else if (week > 35 && week <= 55) {
                explanation = `Biological decelerating curve. Rate drops to ${finalRate} kg/week as the animal hits physiological maturity. Fat deposits displace muscle accumulation.`;
            } else {
                explanation = `The curve plateaus. Maintenance requirements consume feed input with negligible biomass gains. Maintaining past this stage risks reducing profit margins.`;
            }
            
            document.getElementById('outExplanation').innerText = explanation;
            
            // Visual accentuation to track user action
            const cardElement = document.getElementById('analysisCard');
            cardElement.className = cardElement.className.replace(/border-(amber|emerald|blue)-500/g, '');
            
            if (week > 25 && week <= 35) {
                cardElement.classList.add('border-emerald-500');
            } else if (week > 55) {
                cardElement.classList.add('border-blue-500');
            } else {
                cardElement.classList.add('border-amber-500');
            }
        }
    </script>
